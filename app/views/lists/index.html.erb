<div class="container mt-5">
  <div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="fw-bold">Listas de Filmes </h1>
    <%= link_to "Nova Lista", new_list_path, class: "btn btn-success shadow-sm" %>
  </div>

  <div class="row">
    <% if @lists.empty? %>
      <div class="col-12 text-center my-5">
        <p class="text-muted fs-4">Você ainda não criou nenhuma lista de filmes.</p>
        <%= link_to "Criar minha primeira lista", new_list_path, class: "btn btn-primary" %>
      </div>
    <% else %>
      <% @lists.each do |list| %>
        <div class="col-md-4 mb-4">
          <div class="card shadow-sm h-100 border-0 bg-light">
            <div class="card-body d-flex flex-column justify-content-between">
              <div>
                <h3 class="card-title h5 fw-bold text-dark"><%= list.name %></h3>
                <p class="text-secondary small">
                  <%= list.movies.count %> <%= list.movies.count == 1 ? 'filme' : 'filmes' %> nesta lista
                </p>
              </div>

              <div class="d-flex justify-content-between align-items-center mt-3">
                <%= link_to "Ver Detalhes", list_path(list), class: "btn btn-sm btn-outline-primary" %>

                <%= link_to list_path(list),
                            data: { turbo_method: :delete, turbo_confirm: "Tem certeza que deseja apagar a lista '#{list.name}'?" },
                            class: "text-danger" do %>
                  <i class="bi bi-trash"></i> Excluir
                <% end %>
              </div>
            </div>
          </div>
        </div>
      <% end %>
    <% end %>
  </div>
</div>
